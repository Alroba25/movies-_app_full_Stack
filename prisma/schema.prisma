generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "mongodb"
 url      = env("DATABASE_URL")
}

model movie {
 id          String   @id @default(auto()) @map("_id") @db.ObjectId
 title       String
 description String
 poster      String
 rating      Float
 createdAt   DateTime @default(now())
}

model myList {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  movieId   Int
  mediaType String   @default("movie")
  createdAt DateTime @default(now())
}